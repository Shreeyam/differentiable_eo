\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Walker recovery experiment. \textbf  {(a)} Convergence of soft and hard coverage and revisit metrics over 1000 iterations, with Walker 24/6/1 reference (dashed). The optimizer matches Walker performance by iteration $\sim $400. \textbf  {(b)} RAAN vs mean anomaly trajectories. Hollow circles show the initial configuration, solid circles the optimized result, and stars the Walker reference.}}{10}{figure.caption.22}\protected@file@percent }
\newlabel{fig:convergence}{{5}{10}{Walker recovery experiment. \textbf {(a)} Convergence of soft and hard coverage and revisit metrics over 1000 iterations, with Walker 24/6/1 reference (dashed). The optimizer matches Walker performance by iteration $\sim $400. \textbf {(b)} RAAN vs mean anomaly trajectories. Hollow circles show the initial configuration, solid circles the optimized result, and stars the Walker reference}{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Loss landscape visualization~\citep  {li_visualizing_2018}. \textbf  {Left column:} global view along random directions (zoomed out) revealing the broader landscape structure. \textbf  {Columns 2--5:} per-trajectory PCA slices, each showing the landscape along that trajectory's own principal components (white line, circle = start, star = end). \textbf  {Top row:} relaxed total loss. \textbf  {Bottom row:} hard (discrete) total loss. The per-trajectory views show smooth basins, while the global view reveals the multi-modal structure of the full parameter space.}}{10}{figure.caption.23}\protected@file@percent }
\newlabel{fig:landscape}{{6}{10}{Loss landscape visualization~\citep {li_visualizing_2018}. \textbf {Left column:} global view along random directions (zoomed out) revealing the broader landscape structure. \textbf {Columns 2--5:} per-trajectory PCA slices, each showing the landscape along that trajectory's own principal components (white line, circle = start, star = end). \textbf {Top row:} relaxed total loss. \textbf {Bottom row:} hard (discrete) total loss. The per-trajectory views show smooth basins, while the global view reveals the multi-modal structure of the full parameter space}{figure.caption.23}{}}
